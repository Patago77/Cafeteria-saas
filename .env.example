# Base de datos
DATABASE_URL="postgresql://user:password@localhost:5432/cafeteria_saas"

# JWT
JWT_SECRET="generalo-con-openssl-rand-hex-32"

# Encriptación (para tokens de MP — debe ser exactamente 32 bytes en hex = 64 chars)
ENCRYPTION_KEY="generalo-con-node-crypto-randomBytes-32-hex"

# Mercado Pago (tu app como plataforma)
MP_APP_ID="tu-app-id-de-mp"
MP_APP_SECRET="tu-app-secret-de-mp"
MP_REDIRECT_URI="http://localhost:3001/api/onboarding/mp-callback"

# URLs
BASE_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# Email (opcional al inicio)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@cafeteria-saas.com"

# App
PORT="3001"
NODE_ENV="development"
